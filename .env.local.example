# =============================================================================
# WR Doors × DODA — Local environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is in .gitignore — never commit secrets to GitHub.
# =============================================================================

# Public site URL (used in metadata, hreflang, OG tags, sitemaps)
# Local dev: http://localhost:3000
# Production: https://wrdoors.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ----- Supabase (configured in Prompt 7) ----------------------------------
# Public anon key — safe to expose, used by client SDK
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service role key — SECRET — bypasses RLS, server-only
# NEVER prefix with NEXT_PUBLIC_ — that would expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# ----- Resend (email — configured in Prompt 8) -----------------------------
RESEND_API_KEY=""
# "From" address for transactional emails (must be on a verified Resend domain)
RESEND_FROM_EMAIL="WR Doors <noreply@wrdoors.com>"
# Where admin notifications go
ADMIN_NOTIFICATION_EMAIL="wahatalruman36@gmail.com"

# ----- Optional integrations ----------------------------------------------
# Spline scene URL (used in homepage hero, set in Prompt 3)
NEXT_PUBLIC_SPLINE_SCENE_URL=""
